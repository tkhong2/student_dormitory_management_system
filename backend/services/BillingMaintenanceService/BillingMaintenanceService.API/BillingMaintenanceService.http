    {
      "itemName": "Phí dịch vụ",
      "itemDescription": "Vệ sinh, wifi",
      "quantity": 1,
      "unit": "tháng",
      "unitPrice": 150000,
      "sortOrder": 4
    }
  ]
}

###############################################
# Payments API
###############################################

### Get all payments
GET {{baseUrl}}/api/payments

### Get payment by ID
GET {{baseUrl}}/api/payments/1

### Get payments by invoice ID
GET {{baseUrl}}/api/payments/invoice/1

### Create new payment
POST {{baseUrl}}/api/payments
Content-Type: application/json

{
  "invoiceId": 1,
  "amount": 1980000,
  "method": "BankTransfer",
  "transactionCode": "TXN20250103123456",
  "bankName": "Vietcombank",
  "bankAccountNumber": "1234567890",
  "paymentDate": "2025-01-03",
  "receivedByUserId": 1,
  "receivedByName": "Administrator",
  "note": "Thanh toán đầy đủ"
}

###############################################
# Maintenance Requests API
###############################################

### Get all maintenance requests
GET {{baseUrl}}/api/maintenancerequests

### Get maintenance request by ID
GET {{baseUrl}}/api/maintenancerequests/1

### Get maintenance requests by room ID
GET {{baseUrl}}/api/maintenancerequests/room/1

### Get maintenance requests by student ID
GET {{baseUrl}}/api/maintenancerequests/student/1

### Create new maintenance request
POST {{baseUrl}}/api/maintenancerequests
Content-Type: application/json

{
  "roomId": 1,
  "roomNumber": "101",
  "buildingName": "Tòa A",
  "requestedByStudentId": 1,
  "requestedByStudentName": "Nguyen Van A",
  "title": "Điều hòa không hoạt động",
  "description": "Điều hòa phòng 101 không chạy, có thể do hết gas hoặc lỗi máy nén",
  "category": "Electric",
  "priority": "High",
  "imageUrls": null
}

### Assign maintenance request to technician
POST {{baseUrl}}/api/maintenancerequests/1/assign
Content-Type: application/json

{
  "assignedToUserId": 2,
  "assignedToName": "Nguyen Van B",
  "expectedCompletionDate": "2025-01-10",
  "estimatedCost": 500000
}

### Start working on maintenance request
POST {{baseUrl}}/api/maintenancerequests/1/start

### Resolve maintenance request
POST {{baseUrl}}/api/maintenancerequests/1/resolve
Content-Type: application/json

{
  "resolutionNote": "Đã thay gas điều hòa, kiểm tra máy nén hoạt động bình thường",
  "actualCost": 450000,
  "afterImageUrls": null
}

### Rate maintenance request
POST {{baseUrl}}/api/maintenancerequests/1/rate
Content-Type: application/json

{
  "rating": 5,
  "feedback": "Xử lý nhanh chóng, chuyên nghiệp"
}

### Reject maintenance request
POST {{baseUrl}}/api/maintenancerequests/1/reject
Content-Type: application/json

{
  "rejectedReason": "Không phải lỗi của KTX, sinh viên tự tắt máy",
  "rejectedByUserId": 1
}
