@baseUrl = http://localhost:5002
@baseUrlHttps = https://localhost:7002

### Health Check
GET {{baseUrl}}/swagger/index.html

###############################################
# Users API
###############################################

### Get all users
GET {{baseUrl}}/api/users

### Get user by ID
GET {{baseUrl}}/api/users/1

### Create new user
POST {{baseUrl}}/api/users
Content-Type: application/json

{
  "username": "admin",
  "password": "Admin@123",
  "fullName": "Administrator",
  "email": "admin@example.com",
  "phone": "0123456789",
  "role": "Admin"
}

### Create student user
POST {{baseUrl}}/api/users
Content-Type: application/json

{
  "username": "SV001",
  "password": "Student@123",
  "fullName": "Nguyen Van A",
  "email": "student@example.com",
  "phone": "0987654321",
  "role": "Student",
  "studentId": 1,
  "studentCode": "SV001"
}

###############################################
# Invoices API
###############################################

### Get all invoices
GET {{baseUrl}}/api/invoices

### Get invoice by ID
GET {{baseUrl}}/api/invoices/1

### Get invoices by student ID
GET {{baseUrl}}/api/invoices/student/1

### Get invoices by contract ID
GET {{baseUrl}}/api/invoices/contract/1

### Create new invoice
POST {{baseUrl}}/api/invoices
Content-Type: application/json

{
  "invoiceCode": "INV202501001",
  "invoiceType": "Monthly",
  "contractId": 1,
  "studentId": 1,
  "studentName": "Nguyen Van A",
