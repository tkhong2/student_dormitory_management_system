  "previousDebt": 0,
  "discount": 0,
  "dueDate": "2025-01-15",
  "createdByUserId": 1,
  "notes": "Phiếu thu tháng 1/2025",
  "items": [
    {
      "itemName": "Tiền phòng",
      "itemDescription": "Phòng 101 - Tòa A",
      "quantity": 1,
      "unit": "tháng",
